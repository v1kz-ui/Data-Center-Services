            "ACCT"
          ],
          "transform": "strip"
        },
        {
          "target": "parcel_id",
          "transform": "template",
          "template": "DFW:{county_fips}:{apn}"
        },
        {
          "target": "acreage",
          "source": "AREA_FEET",
          "transform": "square_feet_to_acres"
        },
        {
          "target": "geometry_wkt",
          "source": "__geometry__",
          "transform": "geojson_to_wkt"
        },
        {
