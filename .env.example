APP_ENV=local
APP_NAME=dense-data-center-locator
APP_PORT=8000
LOG_LEVEL=INFO
REFERENCE_SEED_DIR=db/seeds
UAT_ENVIRONMENT_NAME=uat
UAT_SCENARIO_PACK_PATH=infra/uat/phase7_uat_scenarios.json
REQUEST_ID_HEADER=X-Request-ID
TRACE_ID_HEADER=X-Trace-ID
MONITORING_FAILED_RUN_THRESHOLD=1
MONITORING_FAILED_SNAPSHOT_THRESHOLD=1
MONITORING_QUARANTINED_SNAPSHOT_THRESHOLD=1
MONITORING_FRESHNESS_FAILURE_THRESHOLD=1
MONITORING_LATEST_BATCH_FAILED_THRESHOLD=1
AUTH_ENABLED=true
AUTH_SUBJECT_HEADER=X-DDCL-Subject
AUTH_NAME_HEADER=X-DDCL-Name
AUTH_ROLES_HEADER=X-DDCL-Roles

DB_HOST=localhost
DB_PORT=5432
DB_NAME=dense_data_center_locator
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=

POSTGIS_ENABLED=true
ACTIVE_BATCH_STRATEGY=activated_only
